# Domain for SSL certificate and nginx config
DOMAIN=draw.gaiachagnon.com

# Email for Let's Encrypt certificate notifications
EMAIL=your-email@example.com

# SHA-256 hash of the site password
# Generate with: echo -n "yourpassword" | sha256sum | cut -d' ' -f1
SITE_PASSWORD_HASH=

# Random secret for signing auth cookies
# Generate with: openssl rand -hex 32
COOKIE_SECRET=

# WebSocket server URL (must match your domain)
VITE_APP_WS_SERVER_URL=wss://draw.gaiachagnon.com/socket.io

# Firebase config JSON (from Firebase console)
VITE_APP_FIREBASE_CONFIG=

# Excalidraw storage backends (defaults to excalidraw.com public API)
VITE_APP_BACKEND_V2_GET_URL=https://json.excalidraw.com/api/v2/
VITE_APP_BACKEND_V2_POST_URL=https://json.excalidraw.com/api/v2/post/
